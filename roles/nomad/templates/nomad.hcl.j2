# {{ ansible_managed }}

name       = "{{ nomad_name }}"
region     = "{{ nomad_region }}"
datacenter = "{{ nomad_datacenter }}"
data_dir   = "{{ nomad_data_dir }}"
log_level  = "{{ nomad_log_level }}"

advertise {
{% raw %}
  http = "{{ GetInterfaceIP \"tailscale0\" }}"
{% endraw %}
  rpc  = "{{ hcloud_private_ipv4 }}"
  serf = "{{ hcloud_private_ipv4 }}"
}

acl {
  enabled = true
}
